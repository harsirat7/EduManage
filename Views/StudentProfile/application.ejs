<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/CSS/application.css">
    <%-include("../Commons/Title/title.ejs")%>
    <%-include("../Commons/CDN/style.ejs")%>
</head>

<body>
    <%-include("../Commons/Header/student_dashboard.ejs")%>

    <div class="application_body">
        <div class="main_heading">
            <h2 class="heading">Write Your Application</h2>
        </div>

        <div class="upperbody">
            <h3 class="labels">To</h3>
            <h3 class="labels">The Principal</h3>
            <h3 class="labels">Endeavour School</h3>
            <h3 class="labels">Date : <%= typeof date !== "undefined" ? date : "" %></h3>
        </div> <br>

        <div class="form_tab">
            <form action="/student_application" method="post" class="form" id="student_application">
                <div>
                    <label for="subject"><h3 class="labels">Subject : </h3></label>
                    <input type="text" name="subject" id="subject" class="sub_input" required> <br><br>
                </div>
                <textarea name="body" id="body" class="app_body"></textarea>
            </form>
        </div>

        <div class="regards_tab">
            <h2 class="labels">Yours Truly,</h2>
            <h2 class="labels"><%= typeof name != "undefined" ? name:""%></h2>
        </div>

        <div class="sub_btn">
            <button class="btnn" type="submit" form="student_application">Submit</button>
        </div>

        <img src="/Img/application.png" alt="image" class="img">

    </div>

    <%if(locals.success){%>
        <script>
            alert("<%=success%>")
        </script>
        <%}%>

    
    
    
    
    
    
    
        <%if(locals.err){%>
        <script>
            alert("<%=err%>")
        </script>
        <%}%>

        <%-include("../Commons/CDN/script.ejs")%>
</body>

</html>